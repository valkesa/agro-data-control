rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userData() {
      return get(userDoc()).data;
    }

    function hasUserContext() {
      return signedIn()
        && exists(userDoc())
        && userData().active == true;
    }

    function isUserActiveTenant(tenantId) {
      return hasUserContext() && userData().activeTenantId == tenantId;
    }

    function memberDoc(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid);
    }

    function membershipData(tenantId) {
      return get(memberDoc(tenantId)).data;
    }

    function isTenantMember(tenantId) {
      return isUserActiveTenant(tenantId)
        && exists(memberDoc(tenantId))
        && membershipData(tenantId).active == true;
    }

    function memberRole(tenantId) {
      return membershipData(tenantId).role;
    }

    // Returns true if the current user is an active tenant_admin of the given tenant.
    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) && memberRole(tenantId) == 'tenant_admin';
    }

    // A tenant_admin may write a members/{uid} document only when:
    //   - they are active tenant_admin of this tenant
    //   - they are not modifying their own record
    //   - the resulting role is strictly 'tenant_operator' (no escalation)
    function canTenantAdminWriteMember(tenantId, targetUid) {
      return isTenantAdmin(tenantId)
        && request.auth.uid != targetUid
        && request.resource.data.role == 'tenant_operator';
    }

    // tenant_admin can edit site-level config; owner always can.
    function canEditTenantConfig(tenantId) {
      return isTenantAdmin(tenantId);
    }

    function isOwner() {
      return hasUserContext() && userData().role == 'owner';
    }

    function isValkeTechnician(tenantId) {
      return hasUserContext()
        && userData().role == 'valke_technician'
        && userData().activeTenantId == tenantId;
    }

    function canReadTenant(tenantId) {
      return isTenantMember(tenantId) || isOwner() || isValkeTechnician(tenantId);
    }

    function allowedComparisonModules() {
      return [
        'Estado',
        'Ambiente',
        'Filtros',
        'Ventilacion',
        'Enfriamiento',
        'Aperturas',
        'Calefaccion',
        'Alarmas'
      ];
    }

    function isValidComparisonModuleOrder(order) {
      return order is list
        && order.size() == allowedComparisonModules().size()
        && order.hasAll(allowedComparisonModules())
        && order.hasOnly(allowedComparisonModules());
    }

    function isValidVisibleUnits(ui) {
      return ui is map
        && ui.keys().hasOnly(['munters1', 'munters2'])
        && ui.munters1 is bool
        && ui.munters2 is bool;
    }

    function isValidManualFanUnit(unit) {
      return unit is map
        && unit.keys().hasOnly(['q5', 'q6', 'q7', 'q8', 'q9', 'q10'])
        && unit.q5 is bool
        && unit.q6 is bool
        && unit.q7 is bool
        && unit.q8 is bool
        && unit.q9 is bool
        && unit.q10 is bool;
    }

    function isValidManualFanStatus(status) {
      return status is map
        && status.keys().hasOnly(['munters1', 'munters2'])
        && isValidManualFanUnit(status.munters1)
        && isValidManualFanUnit(status.munters2);
    }

    function hasValidManualFanStatus() {
      return request.resource.data.ui is map
        && request.resource.data.ui.manualFanStatus is map
        && isValidManualFanStatus(request.resource.data.ui.manualFanStatus);
    }

    function isValidMaintenanceMode(mode) {
      return ['in_situ', 'systems', 'scheduled'].hasAny([mode]);
    }

    function isValidMaintenanceEntry(entry) {
      return isValidMaintenanceMode(entry)
        || (
          entry is map
          && entry.keys().hasOnly(['mode', 'expiresAt'])
          && isValidMaintenanceMode(entry.mode)
          && entry.expiresAt is timestamp
        );
    }

    function isValidMaintenanceSettings(settings) {
      return settings is map
        && settings.keys().hasOnly(['munters1', 'munters2'])
        && (
          !settings.keys().hasAny(['munters1'])
          || isValidMaintenanceEntry(settings.munters1)
        )
        && (
          !settings.keys().hasAny(['munters2'])
          || isValidMaintenanceEntry(settings.munters2)
        );
    }

    function hasValidMaintenanceSettings() {
      return request.resource.data.ui is map
        && request.resource.data.ui.maintenance is map
        && isValidMaintenanceSettings(request.resource.data.ui.maintenance);
    }

    function isManualFanStatusCreate() {
      return request.resource.data.keys().hasOnly(['ui', 'updatedAt', 'updatedByUid'])
        && request.resource.data.ui.keys().hasOnly(['manualFanStatus'])
        && hasValidManualFanStatus();
    }

    function isManualFanStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['ui', 'updatedAt', 'updatedByUid'])
        && hasValidManualFanStatus()
        && (
          (!('ui' in resource.data)
            && request.resource.data.ui.keys().hasOnly(['manualFanStatus']))
          || (
            resource.data.ui is map
            && request.resource.data.ui.diff(resource.data.ui).affectedKeys()
                .hasOnly(['manualFanStatus'])
          )
        );
    }

    function canWriteManualFanStatus(tenantId) {
      return isOwner() || isValkeTechnician(tenantId);
    }

    function isMaintenanceCreate() {
      return request.resource.data.keys().hasOnly(['ui', 'updatedAt', 'updatedByUid'])
        && request.resource.data.ui.keys().hasOnly(['maintenance'])
        && hasValidMaintenanceSettings();
    }

    function isMaintenanceUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['ui', 'updatedAt', 'updatedByUid'])
        && hasValidMaintenanceSettings()
        && (
          (!('ui' in resource.data)
            && request.resource.data.ui.keys().hasOnly(['maintenance']))
          || (
            resource.data.ui is map
            && request.resource.data.ui.diff(resource.data.ui).affectedKeys()
                .hasOnly(['maintenance'])
          )
        );
    }

    function isValidOptionalNumber(field) {
      return !request.resource.data.keys().hasAny([field])
        || request.resource.data[field] is number;
    }

    function isValidElectricalConsumptionSettings() {
      return request.resource.data.keys().hasOnly([
          'fanLevels',
          'humidifierPumpKw',
          'heaterStage1Kw',
          'heaterStage2Kw',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.fanLevels is list
        && request.resource.data.fanLevels.size() <= 100
        && isValidOptionalNumber('humidifierPumpKw')
        && isValidOptionalNumber('heaterStage1Kw')
        && isValidOptionalNumber('heaterStage2Kw')
        && request.resource.data.updatedBy == request.auth.uid
        && (
          !('updatedAt' in request.resource.data)
          || request.resource.data.updatedAt is timestamp
        );
    }

    // A user can switch their own active site, provided the new siteId is
    // already listed in their allowedSiteIds (prevents access to unlisted sites).
    function isOwnSiteSwitch(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['defaultSiteId'])
        && request.resource.data.defaultSiteId is string
        && resource.data.activeTenantId is string
        && resource.data.allowedSiteIds.hasAny([request.resource.data.defaultSiteId])
        && exists(/databases/$(database)/documents/tenants/$(resource.data.activeTenantId)/sites/$(request.resource.data.defaultSiteId));
    }

    function isOwnUiUpdate(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ui'])
        && request.resource.data.ui is map
        && request.resource.data.ui.keys().hasOnly(['comparison', 'visibleUnits'])
        && (
          !('comparison' in request.resource.data.ui)
          || (
            request.resource.data.ui.comparison is map
            && request.resource.data.ui.comparison.keys().hasOnly(['moduleOrder'])
            && isValidComparisonModuleOrder(request.resource.data.ui.comparison.moduleOrder)
          )
        )
        && (
          !('visibleUnits' in request.resource.data.ui)
          || isValidVisibleUnits(request.resource.data.ui.visibleUnits)
        );
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isOwner());
      allow list: if isOwner();

      // New users self-register with role='pending' and active=false.
      // Owner profiles are set directly in Firestore, never via client create.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'pending'
        && request.resource.data.active == false;

      // Owner can update profile fields managed by updateUserAccess().
      // Users can update only their own UI preferences.
      allow update: if (isOwner()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['role', 'activeTenantId', 'defaultSiteId', 'allowedSiteIds',
                        'active', 'updatedAt', 'email']))
        || isOwnUiUpdate(uid)
        || isOwnSiteSwitch(uid);

      allow delete: if false;
    }

    function isValidPresenceDoc(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'displayName',
          'email',
          'role',
          'lastSeenAt',
          'activeSince',
          'isOnline',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'uid',
          'displayName',
          'email',
          'role',
          'lastSeenAt',
          'isOnline',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.displayName is string
        && request.resource.data.email is string
        && request.resource.data.role is string
        && request.resource.data.isOnline is bool
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          !('activeSince' in request.resource.data)
          || request.resource.data.activeSince is timestamp
        );
    }

    match /workspaces/{workspaceId}/presence/{uid} {
      allow get: if isOwner() || (signedIn() && request.auth.uid == uid);
      allow list: if isOwner();
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && isValidPresenceDoc(uid);
      allow delete: if false;
    }

    match /tenants/{tenantId} {
      allow read: if canReadTenant(tenantId);

      match /members/{uid} {
        // A tenant_admin can read all members in their own tenant.
        allow get: if (signedIn() && request.auth.uid == uid && isUserActiveTenant(tenantId))
          || isOwner()
          || isTenantAdmin(tenantId);
        allow list: if isOwner() || isTenantAdmin(tenantId);

        // Owner: unrestricted writes.
        // tenant_admin: can only create a new tenant_operator (not tenant_admin, not owner).
        allow create: if isOwner()
          || canTenantAdminWriteMember(tenantId, uid);

        // Owner: unrestricted updates.
        // tenant_admin: can only update a tenant_operator record (resource.data.role
        //   is the existing role; blocks modifying other admins).
        allow update: if isOwner()
          || (canTenantAdminWriteMember(tenantId, uid)
              && resource.data.role == 'tenant_operator');

        allow delete: if false;
      }

      match /sites/{siteId} {
        allow read: if canReadTenant(tenantId);
        allow update: if isOwner()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['name', 'updatedAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && (
            !('updatedAt' in request.resource.data)
            || request.resource.data.updatedAt is timestamp
          );
        allow create, delete: if false;

        // PLC display configuration (displayName, columnLabel).
        // technicalId is immutable — only owner can write.
        match /plcs/{plcId} {
          allow read: if canReadTenant(tenantId);
          allow create, update: if isOwner()
            && request.resource.data.technicalId == plcId
            && request.resource.data.displayName is string
            && request.resource.data.displayName.size() > 0
            && request.resource.data.columnLabel is string
            && request.resource.data.columnLabel.size() > 0;
          allow delete: if false;

          match /settings/{docId} {
            allow read: if canReadTenant(tenantId);
            allow create, update: if docId == 'electricalConsumption'
              && (canEditTenantConfig(tenantId) || isOwner())
              && isValidElectricalConsumptionSettings();
            allow delete: if false;
          }
        }

        match /settings/{docId} {
          allow read: if canReadTenant(tenantId);
          allow create, update: if docId == 'controlDashboard'
            && (canEditTenantConfig(tenantId) || isOwner());
          allow create: if docId == 'controlDashboard'
            && canWriteManualFanStatus(tenantId)
            && isManualFanStatusCreate();
          allow update: if docId == 'controlDashboard'
            && canWriteManualFanStatus(tenantId)
            && isManualFanStatusUpdate();
          allow create: if docId == 'controlDashboard'
            && canWriteManualFanStatus(tenantId)
            && isMaintenanceCreate();
          allow update: if docId == 'controlDashboard'
            && canWriteManualFanStatus(tenantId)
            && isMaintenanceUpdate();
          allow delete: if false;
        }

        match /doors/{doorId} {
          allow read: if canReadTenant(tenantId);
          allow create, update, delete: if false;

          match /openings/{openingId} {
            allow read: if canReadTenant(tenantId);
            allow delete: if isOwner();
            allow create, update: if false;
          }
        }
      }
    }

    match /tenants/{tenantId}/sites/{siteId}/plcs/{plcId}/metrics/temperature {
      allow read: if canReadTenant(tenantId);
      allow create, update, delete: if false;

      match /hourly/{docId} {
        allow read: if canReadTenant(tenantId);
        allow create, update, delete: if false;
      }

      match /daily/{docId} {
        allow read: if canReadTenant(tenantId);
        allow create, update, delete: if false;
      }
    }

    match /tenants/{tenantId}/sites/{siteId}/plcs/{plcId}/metrics/waterShortage {
      allow read: if canReadTenant(tenantId);
      allow create, update: if isTenantMember(tenantId) || isOwner();
      allow delete: if false;

      match /events/{eventId} {
        allow read: if canReadTenant(tenantId);
        allow create: if isTenantMember(tenantId) || isOwner();
        allow update, delete: if false;
      }

      match /monthly/{monthKey} {
        allow read: if canReadTenant(tenantId);
        allow create, update: if isTenantMember(tenantId) || isOwner();
        allow delete: if false;
      }
    }
  }
}
